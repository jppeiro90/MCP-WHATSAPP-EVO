{
  "name": "mcp-whatsapp-evo",
  "version": "1.0.0",
  "description": "Model Context Protocol (MCP) server exposing the full WhatsApp surface of the Evolution API (messaging, chats, message history, profile, groups, labels, templates and calls).",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/MCP-WHATSAPP-EVO.git"
  },
  "bin": {
    "mcp-whatsapp-evo": "dist/main.cjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "esbuild src/main.ts --bundle --platform=node --outfile=dist/main.cjs --target=node18 --format=cjs",
    "start": "node dist/main.cjs",
    "dev": "node --import tsx src/main.ts",
    "lint": "biome check src",
    "format": "biome format --write src"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/node": "^24.7.0",
    "esbuild": "^0.25.10",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.1.1",
    "axios": "^1.8.4",
    "dotenv": "^16.6.1",
    "zod": "^3.24.1",
    "zod-to-json-schema": "^3.24.1"
  }
}
